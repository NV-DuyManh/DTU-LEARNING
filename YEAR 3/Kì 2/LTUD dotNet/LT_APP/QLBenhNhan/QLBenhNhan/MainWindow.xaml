<Window x:Class="QLBenhNhan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QLBenhNhan"
        mc:Ignorable="d"
        Title="Quản Lý Bệnh Nhân" Height="500" Width="850" WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Quản lý bệnh nhân" Grid.Row="0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Mã BN:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="txtMaBN" Grid.Row="0" Grid.Column="1" Margin="5" Height="25" VerticalContentAlignment="Center"/>

                <TextBlock Text="Họ tên:" Grid.Row="0" Grid.Column="2" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="txtHoTen" Grid.Row="0" Grid.Column="3" Margin="5" Height="25" VerticalContentAlignment="Center"/>

                <TextBlock Text="Giới tính:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton x:Name="rbNam" Content="Nam" Margin="5,0" IsChecked="True"/>
                    <RadioButton x:Name="rbNu" Content="Nữ" Margin="5,0"/>
                </StackPanel>

                <TextBlock Text="Ngày nhập viện:" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center" Margin="5"/>
                <DatePicker x:Name="dpNgayNhapVien" Grid.Row="1" Grid.Column="3" Margin="5"/>

                <TextBlock Text="Khoa:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="cbKhoa" Grid.Row="2" Grid.Column="1" Margin="5" Height="25" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Nội"/>
                    <ComboBoxItem Content="Ngoại"/>
                    <ComboBoxItem Content="Nhi"/>
                </ComboBox>
            </Grid>
        </GroupBox>

        <GroupBox Header="Danh sách bệnh nhân" Grid.Row="1" Margin="0,10,0,10">
            <DataGrid x:Name="dgDanhSach" AutoGenerateColumns="False" CanUserAddRows="False" Margin="5">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã BN" Binding="{Binding MaBN}" Width="*"/>
                    <DataGridTextColumn Header="Họ tên" Binding="{Binding HoTen}" Width="2*"/>
                    <DataGridTextColumn Header="Giới tính" Binding="{Binding GioiTinh}" Width="*"/>
                    <DataGridTextColumn Header="Ngày nhập viện" Binding="{Binding NgayNhapVien, StringFormat=dd/MM/yyyy}" Width="*"/>
                    <DataGridTextColumn Header="Khoa" Binding="{Binding Khoa}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnThem" Content="Thêm" Width="90" Height="30" Margin="10"/>
            <Button x:Name="btnSua" Content="Sửa" Width="90" Height="30" Margin="10"/>
            <Button x:Name="btnXoa" Content="Xóa" Width="90" Height="30" Margin="10"/>
        </StackPanel>
    </Grid>
</Window>