<Window x:Class="QLNhanVien.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QLNhanVien"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <DockPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*"></ColumnDefinition>
                    <ColumnDefinition Width="5*"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <GroupBox Margin="10" Header="Nhap Lieu" Grid.Column="0">
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>
                        </Grid.RowDefinitions>
                        <Label Content="Ma nhan vien: " Grid.Column="0" Grid.Row="0"></Label>
                        <Label Content="Ho ten: " Grid.Column="0" Grid.Row="1"></Label>
                        <Label Content="Ngay sinh: " Grid.Column="0" Grid.Row="2"></Label>
                        <Label Content="Gioi tinh" Grid.Column="0" Grid.Row="3"></Label>
                        <Label Content="Phong ban" Grid.Column="0" Grid.Row="4"></Label>
                        <TextBox Margin="5" Grid.Column="1" Grid.Row="0"></TextBox>
                        <TextBox Margin="5" Grid.Column="1" Grid.Row="1"></TextBox>
                        <DatePicker Margin="5" Grid.Column="1" Grid.Row="2" />
                        <StackPanel Margin="5" Grid.Column="1" Grid.Row="3" Orientation="Horizontal">
                            <RadioButton Margin="5" Content="Nam" ></RadioButton>
                            <RadioButton Margin="5" Content="Nu" ></RadioButton>
                        </StackPanel>
                        <ComboBox Grid.Column="1" Grid.Row="4"></ComboBox>
                        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
                            <Button Name="btnThem" Content="ThêmNV" Width="50" Height="30" Margin="5" Background="LightBlue"/>
                            <Button Name="btnSua" Content="Xoa" Margin="5" Width="50" Height="30" Background="LightPink"/>
                            <Button Name="btnXoa" Content="Cap nhat" Margin="5" Width="50" Height="30" Background="LightGreen"/>
                        </StackPanel>
                       

                    </Grid>
                </GroupBox>
                <GroupBox Margin="10" Header="Chuc Nang" Grid.Column="1">
                    <DataGrid></DataGrid>
                </GroupBox>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
