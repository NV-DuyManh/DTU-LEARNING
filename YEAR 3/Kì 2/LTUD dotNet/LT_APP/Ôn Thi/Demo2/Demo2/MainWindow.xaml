<Window x:Class="Demo2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo2"
        mc:Ignorable="d"
        Title="Quản lý sản phẩm" Height="450" Width="800">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <GroupBox Margin="5" Header="Thông tin sản phẩm">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Margin="5">Mã SP:</Label>
                <Label Grid.Row="1" Grid.Column="0" Margin="5">Tên SP:</Label>
                <Label Grid.Row="2" Grid.Column="0" Margin="5">Ngày nhập:</Label>
                <TextBox Grid.Row="0" Grid.Column="1" Margin="5" ></TextBox>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="5" ></TextBox>
                <DatePicker Grid.Row="2" Grid.Column="1" Margin="5"></DatePicker>
                <Label Grid.Row="0" Grid.Column="2" Margin="5">Loại SP:</Label>
                <Label Grid.Row="1" Grid.Column="2" Margin="5">Tháng bảo hành:</Label>
                <ComboBox Grid.Row="0" Grid.Column="3" Margin="5" ></ComboBox>
                <StackPanel Grid.Row="1" Grid.Column="3" Margin="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton Margin="5">6 tháng</RadioButton>
                    <RadioButton Margin="5">12tháng</RadioButton>
                    <RadioButton Margin="5">24 tháng</RadioButton>
                </StackPanel>
            </Grid>
        </GroupBox>
        <DataGrid Margin="5" Grid.Row="1" AutoGenerateColumns="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã SP" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Tên SP" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Ngày nhập" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Bảo hành (Tháng)" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Loại" Width="*"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Margin="5" Grid.Row="2" HorizontalAlignment="Center" Orientation="Horizontal">
            <Button Margin="5" Width="60" Height="20">Thêm</Button>
            <Button Margin="5" Width="60" Height="20">Sửa</Button>
            <Button Margin="5" Width="60" Height="20">Xoá</Button>
            <Button Margin="5" Width="60" Height="20">Làm mới</Button>
        </StackPanel>
    </Grid>
</Window>
