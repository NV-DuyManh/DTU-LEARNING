<Window x:Class="Demo9.MainWindow"
        Loaded="Window_Loaded"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo9"
        mc:Ignorable="d"
        Title="Nhập liệu tuyển sinh 2025" Height="450" Width="800">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="1.5*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid Margin="5" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Label Margin="5" Grid.Column="0" Grid.Row="0">Mã thí sinh:</Label>
            <Label Margin="5" Grid.Column="0" Grid.Row="1">Họ tên:</Label>
            <Label Margin="5" Grid.Column="0" Grid.Row="2">Ngày sinh:</Label>
            <Label Margin="5" Grid.Column="0" Grid.Row="3">Điểm thi:</Label>
            <Label Margin="5" Grid.Column="0" Grid.Row="4">Ngành học:</Label>
            <TextBox Name="tbMaTS" Margin="5" Grid.Column="1" Grid.Row="0"></TextBox>
            <TextBox Name="tbTen" Margin="5" Grid.Column="1" Grid.Row="1"></TextBox>
            <DatePicker Name="dpNgay"  Margin="5" Grid.Column="1" Grid.Row="2"></DatePicker>
            <TextBox Name="tbDiem" Margin="5" Grid.Column="1" Grid.Row="3"></TextBox>
            <ComboBox Name="cbNganhHoc" Margin="5" Grid.Column="1" Grid.Row="4" SelectionChanged="CbNganhHoc_SelectionChanged"></ComboBox>
            <StackPanel Margin="5" Grid.Column="0" Grid.Row="5" Orientation="Horizontal"  VerticalAlignment="Center" HorizontalAlignment="Center" Grid.ColumnSpan="2">
                <Button Margin="5" Width="50" Height="30" Click="Button_Click">Thêm TS</Button>
                <Button Margin="5" Width="50" Height="30" RenderTransformOrigin="0.504,0.5" Click="Button_Click_1">Xoá</Button>
                <Button Margin="5" Width="50" Height="30" Click="Button_Click_2">Cập nhật</Button>
                <Button Margin="5" Width="50" Height="30" Click="Button_Click_4">Đếm</Button>
                <TextBox Name="tbDem" Width="40" Height="30" Margin="5" IsReadOnly="True" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" TextChanged="TextBox_TextChanged"></TextBox>
            </StackPanel>
        </Grid>
        <Grid Margin="5" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0">Tìm kiếm TS:</Label>
                    <TextBox Name="tbTim" Margin="5" Grid.Column="1"></TextBox>
                    <Button Margin="5" Grid.Column="2" Click="Button_Click_3">Tìm kiếm</Button>
                </Grid>
                <Label Margin="5" Grid.Row="1" FontWeight="Bold">Danh sách:</Label>
            <DataGrid Name="dgTS" Margin="5" Grid.Row="2" AutoGenerateColumns="False" SelectionChanged="DgTS_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Header="MaTS" Binding="{Binding MaTS}"></DataGridTextColumn>
                    <DataGridTextColumn Width="*" Header="HoTen" Binding="{Binding HoTen}"></DataGridTextColumn>
                    <DataGridTextColumn Width="*" Header="NgaySinh" Binding="{Binding NgaySinh}"></DataGridTextColumn>
                    <DataGridTextColumn Width="*" Header="DiemThi" Binding="{Binding DiemThi}"></DataGridTextColumn>
                    <DataGridTextColumn Width="*" Header="MaNganh" Binding="{Binding MaNganh}"></DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
