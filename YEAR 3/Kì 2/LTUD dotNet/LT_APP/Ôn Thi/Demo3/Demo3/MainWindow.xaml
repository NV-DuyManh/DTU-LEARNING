<Window x:Class="Demo3.MainWindow"
        Loaded="Window_Loaded"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo3"
    mc:Ignorable="d"
        Title="Quản lý sản phẩm" Height="450" Width="800">
            
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <GroupBox Grid.Row="0" Margin="5,5,5,5" Header="Thông tin sản phẩm">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Label Margin="5" Grid.Row="0" Grid.Column="0">Mã SP:</Label>
                <TextBox x:Name="MaSP" Margin="5" Grid.Row="0" Grid.Column="1"></TextBox>
                <Label Margin="5" Grid.Row="1" Grid.Column="0">Tên SP:</Label>
                <TextBox x:Name="TenSP" Margin="5" Grid.Row="1" Grid.Column="1"></TextBox>
                <Label Margin="5" Grid.Row="2" Grid.Column="0">Ngày nhập:</Label>
                <DatePicker x:Name="NgayNhap" Margin="5" Grid.Row="2" Grid.Column="1"></DatePicker>
                <Label Margin="5" Grid.Row="0" Grid.Column="2">Loại SP:</Label>
                <ComboBox x:Name="LoaiSP" Margin="5" Grid.Row="0" Grid.Column="3"></ComboBox>
                <Label Margin="5" Grid.Row="1" Grid.Column="2">Tháng bảo hành:</Label>
                <StackPanel x:Name="BaoHanh" Margin="5" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center" Orientation="Horizontal">
                    <RadioButton x:Name="bh6" Margin="5" IsChecked="True">6 tháng</RadioButton>
                    <RadioButton x:Name="bh12" Margin="5">12tháng</RadioButton>
                    <RadioButton x:Name="bh24" Margin="5">24 tháng</RadioButton>
                </StackPanel>
            </Grid>
        </GroupBox>
        <DataGrid x:Name="dataSP" Margin="5,5,5,5" AutoGenerateColumns="False" Grid.Row="1" SelectionChanged="dataSP_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã SP" Width="*" Binding="{Binding MaSP}"></DataGridTextColumn>
                <DataGridTextColumn Header="Ten SP" Width="*" Binding="{Binding TenSP}"></DataGridTextColumn>
                <DataGridTextColumn Header="Ngay nhap" Width="*" Binding="{Binding NgayNhap}"></DataGridTextColumn>
                <DataGridTextColumn Header="Bảo hành (Tháng)" Width="*" Binding="{Binding BaoHanh}"></DataGridTextColumn>
                <DataGridTextColumn Header="Loai" Width="*" Binding="{Binding LOAISP.TenLoai}"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Margin="0,5,0,5" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Margin="5" Width="60" Height="30" Click="Button_Click">Thêm</Button>
            <Button Margin="5" Width="60" Height="30" Click="Button_Click_1">Sửa</Button>
            <Button Margin="5" Width="60" Height="30" Click="Button_Click_2">Xoá</Button>
            <Button Margin="5" Width="60" Height="30" Click="Button_Click_3">Làm mới</Button>
        </StackPanel>
    </Grid>
</Window>
