<Window x:Class="Demo12.MainWindow"
        Loaded="Window_Loaded"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo12"
        mc:Ignorable="d"
        Title="Nhập liệu tuyển sinh 2025" Height="450" Width="800">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="1.5*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid Margin="5" Grid.Column="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Label Margin="5" Grid.Column="0" Grid.Row="0">Mã thí sinh:</Label>
            <Label Margin="5" Grid.Column="0" Grid.Row="1">Họ tên:</Label>
            <Label Margin="5" Grid.Column="0" Grid.Row="2">Ngày sinh:</Label>
            <Label Margin="5" Grid.Column="0" Grid.Row="3">Điểm thi:</Label>
            <Label Margin="5" Grid.Column="0" Grid.Row="4">Ngành học:</Label>
            <TextBox Name="tbMaTS" Margin="5" Grid.Column="1" Grid.Row="0"></TextBox>
            <TextBox Name="tbHoTen" Margin="5" Grid.Column="1" Grid.Row="1"></TextBox>
            <DatePicker Name="dpNgay" Margin="5" Grid.Column="1" Grid.Row="2"></DatePicker>
            <TextBox Name="tbDiem"  Margin="5" Grid.Column="1" Grid.Row="3"></TextBox>
            <ComboBox Name="cbNganhHoc" Margin="5" Grid.Column="1" Grid.Row="4" SelectionChanged="CbNganhHoc_SelectionChanged"></ComboBox>
            <StackPanel  Margin="5" Grid.Column="0" Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Margin="5" Width="60" Height="30" Click="Button_Click">Thêm TS</Button>
                <Button Margin="5" Width="60" Height="30" Click="Button_Click_1">Xoá</Button>
                <Button Margin="5" Width="60" Height="30" Click="Button_Click_2">Cập nhật</Button>
                <Button Margin="5" Width="60" Height="30" Click="Button_Click_3">Làm mới</Button>
            </StackPanel>
            <StackPanel  Margin="5" Grid.Column="0" Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Margin="5" Width="60" Height="30" Click="Button_Click_5" >Đếm TS</Button>
                <TextBox Name="tbDem" IsReadOnly="True" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Margin="5" Width="50"></TextBox>
            </StackPanel>
        </Grid>
        <Grid Margin="5" Grid.Column="1" >
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label Margin="5" Grid.Column="0">Nhập để tìm kiếm</Label>
                    <TextBox Name="tbTim" Margin="10 0 10 0" Grid.Column="1"></TextBox>
                    <Button Grid.Column="2" Width="60" Click="Button_Click_4">Tìm kiếm</Button>
                </Grid>
            </StackPanel>
            <Label Margin="5" Grid.Row="1" FontWeight="Bold">Danh sách:</Label>
            <DataGrid Name="dgTS" Margin="5" Grid.Row="2" AutoGenerateColumns="False" SelectionChanged="DgTS_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="*" Header="Ma TS" Binding="{Binding MaTS }"></DataGridTextColumn>
                    <DataGridTextColumn Width="*" Header="Họ tên" Binding="{Binding HoTen}"></DataGridTextColumn>
                    <DataGridTextColumn Width="*" Header="Ngay sinh" Binding="{Binding NgaySinh}"></DataGridTextColumn>
                    <DataGridTextColumn Width="*" Header="Diem thi" Binding="{Binding DiemThi}"></DataGridTextColumn>
                    <DataGridTextColumn Width="*" Header="Ma nganh" Binding="{Binding MaNganh}"></DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
      
    </Grid>
</Window>
