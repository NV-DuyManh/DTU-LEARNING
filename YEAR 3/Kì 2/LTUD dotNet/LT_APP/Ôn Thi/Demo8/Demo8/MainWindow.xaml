<Window x:Class="Demo8.MainWindow"
        Loaded="Window_Loaded"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo8"
        mc:Ignorable="d"
        Title="Nhập liệu tuyển sinh 2025" Height="314.428" Width="800">
    <Grid Margin="5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
            <ColumnDefinition Width="1.5*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <Grid Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>
            <Label Margin="5" Grid.Column="0" Grid.Row="0">Mã thí sinh:</Label>
            <Label Margin="5" Grid.Column="0" Grid.Row="1">Họ tên:</Label>
            <Label Margin="5" Grid.Column="0" Grid.Row="2">Ngày thi:</Label>
            <Label Margin="5" Grid.Column="0" Grid.Row="3">Điểm thi:</Label>
            <Label Margin="5" Grid.Column="0" Grid.Row="4">Ngành học:</Label>
            <StackPanel Margin="5" Grid.Column="0" Grid.Row="5" Orientation="Horizontal" Grid.ColumnSpan="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button Margin="5" Width="50" Height="30" Click="Button_Click">Thêm TS</Button>
                <Button Margin="5" Width="50" Height="30" Click="Button_Click_1">Xoá</Button>
                <Button Margin="5" Width="50" Height="30" Click="Button_Click_2">Cập nhật</Button>
                <Button Margin="5" Width="50" Height="30" Click="Button_Click_4" >Đếm</Button>
                <TextBox Name="tbDem" Margin="5" Width="30" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" IsReadOnly="True"></TextBox>
            </StackPanel>
            <TextBox Name="tbMaTS" Margin="5" Grid.Column="1" Grid.Row="0" TextChanged="TextBox_TextChanged"></TextBox>
            <TextBox Name="tbHoTen" Margin="5" Grid.Column="1" Grid.Row="1"></TextBox>
            <DatePicker Name="dpNgay" Margin="5" Grid.Column="1" Grid.Row="2"></DatePicker>
            <TextBox Name="tbDiem" Margin="5" Grid.Column="1" Grid.Row="3"></TextBox>
            <ComboBox Name="cbNganh" Margin="5" Grid.Column="1" Grid.Row="4"></ComboBox>
        </Grid>
        <Grid Margin="5" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="60"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0">Nhập để tìm kiếm:</Label>
                    <TextBox Name="tbTim" Margin="5" Grid.Column="1" ></TextBox>
                    <Button  Margin="5.2,5,4.8,0" Grid.Column="2" RenderTransformOrigin="0.504,0.5" Height="19" VerticalAlignment="Top" Click="Button_Click_3">Tìm kiếm</Button>
                </Grid>
            </StackPanel>
            
            <Label Grid.Row="1" FontWeight="Bold">Danh Sách:</Label>
            <DataGrid Name="dgDS" Grid.Row="2" AutoGenerateColumns="False" SelectionChanged="DataGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding MaTS}" Header="Ma TS" Width="*"></DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding HoTen}" Header="Ho Ten" Width="*"></DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding NgaySinh}" Header="Ngay Sinh" Width="*"></DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding DiemThi}" Header="Diem Thi" Width="*"></DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding MaNganh}" Header="Ma Nganh" Width="*"></DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

    </Grid>
</Window>
