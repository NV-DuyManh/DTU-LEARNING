<Window x:Class="Demo13.MainWindow"
        Loaded="Window_Loaded"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo13"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <GroupBox Margin="5" Grid.Row="0">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Label Margin="5" Grid.Column="0" Grid.Row="0">ID Vật Tư</Label>
                <Label Margin="5" Grid.Column="0" Grid.Row="1">Mã Vật Tư</Label>
                <Label Margin="5" Grid.Column="0" Grid.Row="2">Tên Vật Tư</Label>
                <TextBox Name="tbMaVT" Margin="5" Grid.Column="1" Grid.Row="1"></TextBox>
                <TextBox Name="tbTenVT" Margin="5" Grid.Column="1" Grid.Row="2"></TextBox>
                <Button Margin="5" Grid.Column="2" Width="60" Grid.Row="0" Click="Button_Click_4">Đếm</Button>
                <TextBox Name="tbDem" Margin="5" Grid.Column="3" Grid.Row="0" Width="100"></TextBox>
                <ComboBox Name="cbNSX" Margin="4.8,4.8,0,5.4" Grid.Column="2" Grid.ColumnSpan="2" Grid.Row="1" HorizontalAlignment="Left" Width="171" SelectionChanged="CbNSX_SelectionChanged"></ComboBox>
                <DatePicker Name="dpNgay" Margin="5" Grid.Column="4" Grid.Row="0"></DatePicker>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1" Margin="5">
            <StackPanel Margin="5" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button Margin="5" Width="60" Height="30" Click="Button_Click">Thêm</Button>
                <Button Margin="5" Width="60" Height="30" Click="Button_Click_1">Sửa</Button>
                <Button Margin="5" Width="60" Height="30" Click="Button_Click_2">Xoá</Button>
                <Button Margin="5" Width="60" Height="30" Click="Button_Click_3">Load Lại</Button>
            </StackPanel>
        </GroupBox>
        <DataGrid Name="dgVT" Grid.Row="2" Margin="5" AutoGenerateColumns="False" SelectionChanged="DataGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Width="*" Header="Mã Vật Tư" Binding="{Binding MaVatTu}"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="Tên Vật Tư" Binding="{Binding TenVatTu}"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="Ngày Sản Xuất" Binding="{Binding NgaySanXuat}"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="Mã Nhà SX" Binding="{Binding MaNSX}"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
