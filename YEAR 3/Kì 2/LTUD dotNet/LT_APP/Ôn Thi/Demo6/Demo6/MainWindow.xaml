<Window x:Class="Demo6.MainWindow"
        Loaded="Window_Loaded"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo6"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <GroupBox Margin="5" Grid.Row="0">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Margin="5">ID Vật Tư: </Label>
                <Label Grid.Row="1" Grid.Column="0" Margin="5">Mã Vật Tư:</Label>
                <Label Grid.Row="2" Grid.Column="0" Margin="5">Tên Vật Tư:</Label>
                <TextBox x:Name="tbMa" Grid.Row="1" Grid.Column="1" Margin="5"></TextBox>
                <TextBox x:Name="tbTen" Grid.Row="2" Grid.Column="1" Margin="5"></TextBox>
                <Button x:Name="btDem" Width="60" Grid.Row="0" Grid.Column="2" Margin="5" Click="BtDem_Click">Đếm</Button>
                <TextBox x:Name="tbDem" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" IsReadOnly="True" Grid.Row="0" Grid.Column="3" Margin="5" TextChanged="TbDem_TextChanged"></TextBox>
                <ComboBox x:Name="cbNSX" Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="5" SelectionChanged="CbNSX_SelectionChanged"></ComboBox>
                <DatePicker x:Name="dpNgay" Grid.Row="0" Grid.Column="4" Margin="5"></DatePicker>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="1" Margin="5" >
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" >
                <Button Background="LightGreen" Width="60" Height="30" Margin="5" Click="Button_Click">Thêm</Button>
                <Button Background="LightYellow" Width="60" Height="30" Margin="5" Click="Button_Click_1">Sửa</Button>
                <Button Background="LightPink" Width="60" Height="30" Margin="5" Click="Button_Click_2">Xoá</Button>
                <Button Background="LightCyan" Width="60" Height="30" Margin="5" Click="Button_Click_3">Load lại</Button>
            </StackPanel>
        </GroupBox>
        <DataGrid Grid.Row="2" x:Name="dgVatTu" Margin="5" AutoGenerateColumns="False" SelectionChanged="DgVatTu_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Width="*" Header="Mã Vật Tư" Binding="{Binding MaVatTu}"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="Tên Vật Tư" Binding="{Binding TenVatTu}"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="Ngày Sản Xuất" Binding="{Binding NgaySanXuat}"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="Mã NSX" Binding="{Binding MaNSX}"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
