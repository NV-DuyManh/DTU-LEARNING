<Window x:Class="Demo4.MainWindow"
        Loaded="Window_Loaded"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo4"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <GroupBox Grid.Row="0" Header="Thông tin sản phẩm" Margin="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Label Margin="5" Grid.Row="0" Grid.Column="0">Mã SP:</Label>
                <Label Margin="5" Grid.Row="1" Grid.Column="0">Tên SP:</Label>
                <Label Margin="5" Grid.Row="2" Grid.Column="0">Ngày nhập: </Label>
                <Label Margin="5" Grid.Row="0" Grid.Column="2">Loại SP:</Label>
                <Label Margin="5" Grid.Row="1" Grid.Column="2">Tháng bảo hành:</Label>
                <TextBox x:Name="tbMaSP" Margin="5" Grid.Row="0" Grid.Column="1" ></TextBox>
                <TextBox x:Name="tbTenSP" Margin="5" Grid.Row="1" Grid.Column="1"></TextBox>
                <DatePicker x:Name="dpNgayNhap" Margin="5" Grid.Row="2" Grid.Column="1"></DatePicker>
                <ComboBox x:Name="cbLoaiSP" Margin="5" Grid.Row="0" Grid.Column="3" ></ComboBox>
                <StackPanel x:Name="spBaoHanh" Orientation="Horizontal" VerticalAlignment="Center" Margin="5" Grid.Row="1" Grid.Column="3" >
                    <RadioButton x:Name="bh6" Margin="5">6 tháng</RadioButton>
                    <RadioButton x:Name="bh12" Margin="5">12tháng</RadioButton>
                    <RadioButton x:Name="bh24" Margin="5">24tháng</RadioButton>
                </StackPanel>
            </Grid>
        </GroupBox>
        <DataGrid x:Name="dgSP" Grid.Row="1" AutoGenerateColumns="False" Margin="5" SelectionChanged="dgSP_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã SP" Binding="{Binding MaSP}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Tên SP" Binding="{Binding TenSP}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Ngày nhập" Binding="{Binding NgayNhap }" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Bảo hành (Tháng)" Binding="{Binding BaoHanh}" Width="*"></DataGridTextColumn>
                <DataGridTextColumn Header="Loại" Binding="{Binding MaLoai}" Width="*"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Margin="5" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Button Margin="5" Width="60" Height="30" Click="Button_Click">Thêm</Button>
            <Button Margin="5" Width="60" Height="30" Click="Button_Click_1">Sửa</Button>
            <Button Margin="5" Width="60" Height="30" Click="Button_Click_2">Xoá</Button>
            <Button Margin="5" Width="60" Height="30" Click="Button_Click_3">Làm mới</Button>

            <Button x:Name="btnDem" Content="Đếm" Margin="20,5,5,5" Width="60" Height="30" Click="btnDem_Click"/>
            <TextBox x:Name="tbDem" Width="50" Height="30" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" IsReadOnly="True" Margin="5"/>

            <!--<Label Content="Tổng số SP:" VerticalAlignment="Center" Margin="15,0,0,0" FontWeight="Bold"/>
            <TextBlock x:Name="txtSoLuong" Text="0" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="Red" FontWeight="Bold"/>-->
        </StackPanel>
    </Grid>
</Window>
