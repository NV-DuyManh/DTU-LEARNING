<Window x:Class="Demo5.MainWindow"
        Loaded="Window_Loaded"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Demo5"
        mc:Ignorable="d"
        Title="Quản lý sản phẩm" Height="450" Width="800">
    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>
        <GroupBox Grid.Row="0" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Label Margin="5" Grid.Row="0" Grid.Column="0">Mã SP:</Label>
                <Label Margin="5" Grid.Row="1" Grid.Column="0">Tên SP:</Label>
                <Label Margin="5" Grid.Row="2" Grid.Column="0">Ngày nhập:</Label>
                <Label Margin="5" Grid.Row="0" Grid.Column="2">Loại SP:</Label>
                <Label Margin="5" Grid.Row="1" Grid.Column="2">Tháng bảo hành:</Label>
                <TextBox x:Name="tbMaSP" Margin="5" Grid.Row="0" Grid.Column="1"></TextBox>
                <TextBox x:Name="tbTenSP" Margin="5" Grid.Row="1" Grid.Column="1"></TextBox>
                <DatePicker x:Name="dpNgayNhap" Margin="5" Grid.Row="2" Grid.Column="1"></DatePicker>
                <ComboBox x:Name="cbLoaiSP" Margin="5" Grid.Row="0" Grid.Column="3"></ComboBox>
                <StackPanel x:Name="spBaoHanh" Margin="5" Grid.Row="1" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    <RadioButton x:Name="bh6" Margin="5" IsChecked="True">6 tháng</RadioButton>
                    <RadioButton x:Name="bh12" Margin="5">12 tháng</RadioButton>
                    <RadioButton x:Name="bh24" Margin="5">24 tháng</RadioButton>
                </StackPanel>
            </Grid>
        </GroupBox>
        <DataGrid x:Name="dgSP" Margin="5" Grid.Row="1" AutoGenerateColumns="False" SelectionChanged="DgSP_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Width="*" Header="Mã SP" Binding="{Binding MaSP}"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="Tên SP" Binding="{Binding TenSP}"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="Ngày nhập" Binding="{Binding NgayNhap}"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="Bảo hành (Tháng)" Binding="{Binding BaoHanh}"></DataGridTextColumn>
                <DataGridTextColumn Width="*" Header="Loại" Binding="{Binding MaLoai}"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Margin="5" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Margin="5,5,5,0" Width="60" Height="30" VerticalAlignment="Top" Click="Button_Click">Thêm</Button>
            <Button Margin="5" Width="60" Height="30" Click="Button_Click_1">Sửa</Button>
            <Button Margin="5" Width="60" Height="30" Click="Button_Click_2">Xoá</Button>
            <Button Margin="5" Width="60" Height="30" Click="Button_Click_3">Làm mới</Button>
            <Button Margin="5,0,5,5" Width="60" Click="Button_Click_4" Height="30" VerticalAlignment="Bottom">Đếm</Button>
            <TextBox x:Name="demSP" Margin="5" Width="30" Height="30" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" IsReadOnly="True"></TextBox>
            <TextBox x:Name="demSP2" Margin="5" Width="30" Height="30" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" IsReadOnly="True"></TextBox>

        </StackPanel>
    </Grid>
</Window>
