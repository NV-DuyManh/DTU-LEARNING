<Window x:Class="QLVatTu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Vật Tư" Height="500" Width="750"
        Loaded="Window_Loaded">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="196"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="ID Vật Tư" VerticalAlignment="Center" Margin="5" Height="26"/>
            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" >
                <Button x:Name="btnDem" Content="Đếm" Width="70" HorizontalAlignment="Left" Margin="5,6,0,6" Click="btnDem_Click"/>
                <TextBox x:Name="txtDem" Width="60" HorizontalAlignment="Left" Margin="5,6,0,6" VerticalContentAlignment="Center" IsReadOnly="True"/>
            </StackPanel>

            <DatePicker x:Name="dtpNgaySX" Grid.Row="0" Grid.Column="3" Width="150" HorizontalAlignment="Left" Margin="5,6,0,6"/>

            <Label Grid.Row="1" Grid.Column="0" Content="Mã Vật Tư" VerticalAlignment="Center" Margin="5" Height="26"/>
            <TextBox x:Name="txtMaVatTu" Grid.Row="1" Grid.Column="1"  Margin="5,6,30,0" VerticalContentAlignment="Center"/>

            <ComboBox x:Name="cboNSX" Grid.Row="1" Grid.Column="2" Margin="5,6,30,0" VerticalContentAlignment="Center" SelectionChanged="cboNSX_SelectionChanged"/>

            <Label Grid.Row="2" Grid.Column="0" Content="Tên Vật Tư" VerticalAlignment="Center" Margin="5" Height="26"/>
            <TextBox x:Name="txtTenVatTu" Grid.Row="2" Grid.Column="1"  Margin="5,6,30,0" VerticalContentAlignment="Center"/>
        </Grid>

        <Border Grid.Row="1" BorderBrush="#D3D3D3" BorderThickness="1" Padding="10" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnThem" Content="Thêm" Width="70" Height="30" Margin="0,0,20,0" Background="#E0E0E0" Click="btnThem_Click"/>
                <Button x:Name="btnSua" Content="Sửa" Width="70" Height="30" Margin="0,0,20,0" Background="#E0E0E0" Click="btnSua_Click"/>
                <Button x:Name="btnXoa" Content="Xoá" Width="70" Height="30" Margin="0,0,20,0" Background="#E0E0E0" Click="btnXoa_Click"/>
                <Button x:Name="btnLoad" Content="Load Lại" Width="100" Height="30" Margin="20,0,0,0" Background="#E0E0E0" Click="btnLoad_Click"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" x:Name="dgVatTu" AutoGenerateColumns="False" 
                  CanUserAddRows="False" HeadersVisibility="Column"
                  RowHeight="25" GridLinesVisibility="All" AlternatingRowBackground="White"
                  SelectionChanged="dgVatTu_SelectionChanged" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Vật Tư" Binding="{Binding MaVatTu}" Width="80"/>
                <DataGridTextColumn Header="Tên Vật Tư" Binding="{Binding TenVatTu}" Width="120"/>
                <DataGridTextColumn Header="Ngày Sản Xuất" Binding="{Binding NgaySanXuat, StringFormat=\{0:dd/MM/yyyy\}}" Width="150"/>
                <DataGridTextColumn Header="Mã Nhà SX" Binding="{Binding MaNSX}" Width="100"/>
                <DataGridTextColumn Header="" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>