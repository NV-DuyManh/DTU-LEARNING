<Window x:Class="QUANLYTUYENSINH.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nhập liệu tuyển sinh 2025" Height="450" Width="850"
        Loaded="Window_Loaded">
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Content="Mã thí sinh:" Margin="0,5" VerticalAlignment="Center"/>
            <TextBox x:Name="txtMaTS" Grid.Row="0" Grid.Column="1" Height="25" Margin="0,5"/>

            <Label Grid.Row="1" Content="Họ tên:" Margin="0,5" VerticalAlignment="Center"/>
            <TextBox x:Name="txtHoTen" Grid.Row="1" Grid.Column="1" Height="25" Margin="0,5"/>

            <Label Grid.Row="2" Content="Ngày sinh:" Margin="0,5" VerticalAlignment="Center"/>
            <DatePicker x:Name="dtpNgaySinh" Grid.Row="2" Grid.Column="1" Height="25" Margin="0,5"/>

            <Label Grid.Row="3" Content="Điểm thi:" Margin="0,5" VerticalAlignment="Center"/>
            <TextBox x:Name="txtDiemThi" Grid.Row="3" Grid.Column="1" Height="25" Margin="0,5"/>

            <Label Grid.Row="4" Content="Ngành học:" Margin="0,5" VerticalAlignment="Center"/>
            <ComboBox x:Name="cboNganhHoc" Grid.Row="4" Grid.Column="1" Height="25" Margin="0,5"/>

            <Label Grid.Row="5" Content="Giới tính:" Margin="0,5" VerticalAlignment="Center"/>
            <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <RadioButton x:Name="rbNam" Content="Nam" IsChecked="True" Margin="0,0,20,0"/>
                <RadioButton x:Name="rbNu" Content="Nữ"/>
            </StackPanel>

            <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,15,0,0">
                <Button x:Name="btnThem" Content="Thêm TS" Width="85" Height="25" Margin="0,0,10,0" Click="btnThem_Click"/>
                <Button x:Name="btnXoa" Content="Xoá" Width="85" Height="25" Margin="0,0,10,0" Click="btnXoa_Click"/>
                <Button x:Name="btnCapNhat" Content="Cập nhật" Width="85" Height="25" Click="btnCapNhat_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Label Grid.Row="0" Content="Danh sách:" FontWeight="Bold" Margin="0,0,0,5"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBox x:Name="txtTimKiem" Width="200" Height="25" Margin="0,0,10,0"/>
                <Button x:Name="btnTim" Content="Tìm kiếm" Width="75" Height="25" Click="btnTim_Click"/>
            </StackPanel>

            <DataGrid x:Name="dgDanhSach" Grid.Row="2" Background="LightGray" AutoGenerateColumns="True" SelectionChanged="dgDanhSach_SelectionChanged"/>
        </Grid>
    </Grid>
</Window>