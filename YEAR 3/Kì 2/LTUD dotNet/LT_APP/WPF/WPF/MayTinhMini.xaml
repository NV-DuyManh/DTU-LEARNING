<Window x:Class="WPF.MayTinhMini"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <Style x:Key="CssLikeButton" TargetType="Button">
            <Setter Property="Background" Value="#3498db"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                            <ContentPresenter
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2980b9"/>
                            </Trigger>

                            <!-- Click -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1f618d"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Label Name="txt_1" Content="Số 1: " HorizontalAlignment="Left" Margin="131,77,0,0" VerticalAlignment="Top" RenderTransformOrigin="-3.055,1.461"/>
        <Label Name="txt_2" Content="Số 2: " HorizontalAlignment="Left" Margin="131,134,0,0" VerticalAlignment="Top"/>
        <Button Name="btn_cong" Content="Cộng" HorizontalAlignment="Left" Margin="174,215,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click"/>
        <TextBox Name="txt_nhap1" HorizontalAlignment="Left" Height="23" Margin="229,80,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="207"/>
        <TextBox Name="txt_nhap2" HorizontalAlignment="Left" Height="23" Margin="229,134,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="207" TextChanged="Txt_nhap2_TextChanged"/>
        <Button Name="btn_tru" Content="Trừ" HorizontalAlignment="Left" Margin="380,215,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click"/>
        <Button Name="btn_nhan" Content="Nhân" HorizontalAlignment="Left" Margin="174,264,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click"/>
        <Button Name="btn_chia" Content="Chia" HorizontalAlignment="Left" Margin="380,264,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click"/>

    </Grid>

</Window>
