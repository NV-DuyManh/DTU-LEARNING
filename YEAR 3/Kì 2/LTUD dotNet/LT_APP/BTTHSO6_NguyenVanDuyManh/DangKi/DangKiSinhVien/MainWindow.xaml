<Window x:Class="DangKiSinhVien.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DangKiSinhVien"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="500">
    <Grid>
        <Grid.BindingGroup>
            <BindingGroup/>
        </Grid.BindingGroup>
        <Label Content="FORM ĐĂNG KÝ SINH VIÊN" HorizontalAlignment="Left" Margin="64,20,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="20"/>
        <Label Content="Họ tên: " HorizontalAlignment="Left" Margin="31,86,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.384,0.639"/>
        <TextBox Name="hoTen" HorizontalAlignment="Left" Height="23" Margin="130,89,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="250"/>
        <Label Content="MSSV: " HorizontalAlignment="Left" Margin="31,136,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.384,0.639"/>
        <TextBox Name="MSSV" HorizontalAlignment="Left" Height="23" Margin="130,138,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="250"/>
        <Label Content="Ngày sinh: " HorizontalAlignment="Left" Margin="31,190,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.384,0.639"/>
        <DatePicker Name="ngaySinh" HorizontalAlignment="Left" Margin="130,192,0,0" VerticalAlignment="Top" Width="250"/>
        <Label Content="Giới tính: " HorizontalAlignment="Left" Margin="31,238,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.384,0.639"/>
        <RadioButton Name="nam" Content="Nam" GroupName="GioiTinh" IsChecked="True" HorizontalAlignment="Left" Margin="155,248,0,0" VerticalAlignment="Top" />
        <RadioButton Name="nu" Content="Nữ" GroupName="GioiTinh" HorizontalAlignment="Left" Margin="255,248,0,0" VerticalAlignment="Top" />
        <Label Content="Lớp học:" HorizontalAlignment="Left" Margin="31,280,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.384,0.639"/>
        <ComboBox Name="lopHoc" HorizontalAlignment="Left" Margin="130,283,0,0" VerticalAlignment="Top" Width="250" SelectionChanged="ComboBox_SelectionChanged">
            <ComboBoxItem Content="Lớp 10"/>
            <ComboBoxItem Content="Lớp 11"/>
            <ComboBoxItem Content="Lớp 12"/>
        </ComboBox>
        <Label Content="Số điện thoại: " HorizontalAlignment="Left" Margin="31,326,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.384,0.639"/>
        <TextBox Name="SDT" HorizontalAlignment="Left" Height="23" Margin="130,328,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="155"/>
        <Label Content="Email: " HorizontalAlignment="Left" Margin="31,372,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.384,0.639"/>
        <TextBox Name="email" HorizontalAlignment="Left" Height="23" Margin="130,374,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="250"/>
        <Label Content="Ghi chú: " HorizontalAlignment="Left" Margin="31,414,0,0" VerticalAlignment="Top" RenderTransformOrigin="-0.384,0.639"/>
        <TextBox Name="ghiChu" HorizontalAlignment="Left" Height="55" Margin="130,416,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="250"/>
        <Button Name="Luu" Content="Lưu" HorizontalAlignment="Left" Margin="64,517,0,0" VerticalAlignment="Top" Width="75" Click="Luu_Click"/>
        <Button Name="Xoa" Content="Xoá" HorizontalAlignment="Left" Margin="210,517,0,0" VerticalAlignment="Top" Width="75" RenderTransformOrigin="1.8,0.094" Click="Xoa_Click"/>
        <Button Name="Thoat" Content="Thoát" HorizontalAlignment="Left" Margin="351,517,0,0" VerticalAlignment="Top" Width="75" RenderTransformOrigin="1.8,0.094" Click="Thoat_Click"/>

    </Grid>
</Window>
